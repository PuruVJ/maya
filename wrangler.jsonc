{
	"$schema": "node_modules/wrangler/config-schema.json",
	"name": "generative-webgame",
	"main": ".svelte-kit/cloudflare/_worker.js",
	"compatibility_date": "2025-06-01",
	"compatibility_flags": ["nodejs_compat"],
	"assets": {
		"binding": "ASSETS",
		"directory": ".svelte-kit/cloudflare"
	},
	"observability": { "enabled": true }

	// The game is 100% LOCAL (single-player; "local & free"). The whole world lives in the player's browser
	// (IndexedDB) — there is NO backend: no D1, no KV, no Durable Objects. Deploy is just static assets + the
	// SvelteKit worker shell (which only serves them; the only route is the dev-only /api/debug log sink).
	//
	// ── Model weights ─────────────────────────────────────────────────────────────────────────────────
	// The ~840 MB / ~280 MB fine-tunes in static/models/** are EXCLUDED from CF assets (25 MiB/file limit)
	// via static/.assetsignore. For prod they live in R2 (or Hugging Face); point TUNED[...].url in
	// src/lib/llm.svelte.ts at that absolute URL. Local `vite dev` keeps serving them from static/models/.
}
