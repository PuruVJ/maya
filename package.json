{
	"name": "generative-webgame",
	"private": true,
	"version": "0.0.1",
	"type": "module",
	"scripts": {
		"dev": "vite dev",
		"build": "vite build",
		"preview": "vite preview",
		"deploy": "vite build && wrangler deploy",
		"cf-types": "wrangler types",
		"test": "vitest run",
		"test:watch": "vitest",
		"test:llm": "node scripts/fetch-test-model.mjs && vitest run --config vitest.llm.config.ts",
		"test:rust": "cargo test",
		"build:wasm": "wasm-pack build crates/worldsim --target web --out-dir ../../static/worldsim",
		"gen:dataset": "tsx training/gen-dataset.ts",
		"prepare": "svelte-kit sync || echo ''",
		"check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
		"check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch"
	},
	"devDependencies": {
		"@sveltejs/adapter-cloudflare": "^7.2.9",
		"@sveltejs/kit": "^2.63.0",
		"@sveltejs/vite-plugin-svelte": "^7.1.2",
		"@tailwindcss/vite": "^4.3.1",
		"@types/node": "^25.9.3",
		"@types/three": "^0.184.1",
		"node-llama-cpp": "^3.18.1",
		"svelte": "^5.56.1",
		"svelte-check": "^4.6.0",
		"tailwindcss": "^4.3.1",
		"tsx": "^4.22.4",
		"typescript": "^6.0.3",
		"vite": "^8.0.16",
		"vitest": "^4.1.9",
		"wrangler": "^4.103.0"
	},
	"dependencies": {
		"@dimforge/rapier3d-compat": "^0.19.3",
		"@huggingface/transformers": "^4.2.0",
		"@mlc-ai/web-llm": "^0.2.84",
		"@threlte/core": "^8.5.16",
		"@threlte/extras": "^9.21.0",
		"@threlte/rapier": "^3.5.0",
		"clsx": "^2.1.1",
		"tailwind-merge": "^3.6.0",
		"tailwind-variants": "^3.2.2",
		"three": "^0.184.0"
	}
}
